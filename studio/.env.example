# Sanity project for this studio (your correct account).
# 1. Log in at https://www.sanity.io and go to https://www.sanity.io/manage
# 2. Create a new project (or pick an existing one)
# 3. Copy the project ID from the URL (sanity.io/manage/project/YOUR_PROJECT_ID) or from Project settings → API
# 4. Copy this file to .env and set your values:
#
# SANITY_STUDIO_PROJECT_ID=your_project_id_here
# SANITY_STUDIO_DATASET=production
#
# 5. In home-new.html (or your site), set SANITY_PROJECT_ID to the same value so the frontend loads projects from this project.
#
# Optional: For the Vimeo field (paste video URL or ID), create a token at https://developer.vimeo.com/apps
# and add it here so the studio can fetch video metadata (title, thumbnails, etc.).

SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production
# Optional: Vimeo plugin — create token at https://developer.vimeo.com/apps
SANITY_STUDIO_VIMEO_ACCESS_TOKEN=
